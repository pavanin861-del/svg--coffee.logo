<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="cupGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#8B6F47;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#5C4A31;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="steamGradient" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#E8D7C3;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#E8D7C3;stop-opacity:0" />
    </linearGradient>
  </defs>

  <!-- Coffee Cup Body -->
  <path d="M 50 70 L 55 150 Q 55 160 65 160 L 135 160 Q 145 160 145 150 L 150 70 Z" 
        fill="url(#cupGradient)" stroke="#3D2817" stroke-width="2"/>

  <!-- Cup Highlight (shine) -->
  <ellipse cx="75" cy="90" rx="12" ry="20" fill="white" opacity="0.3"/>

  <!-- Coffee inside cup -->
  <path d="M 58 140 L 62 150 Q 62 158 70 158 L 130 158 Q 138 158 138 150 L 142 140 Z" 
        fill="#4A3728" opacity="0.8"/>

  <!-- Cup Handle -->
  <path d="M 145 90 Q 165 95 165 120 Q 165 145 145 145" 
        fill="none" stroke="url(#cupGradient)" stroke-width="5" stroke-linecap="round"/>
  <path d="M 145 90 Q 165 95 165 120 Q 165 145 145 145" 
        fill="none" stroke="#3D2817" stroke-width="2" stroke-linecap="round"/>

  <!-- Steam Wisps - Left -->
  <path d="M 80 65 Q 75 50 80 35 Q 85 20 80 10" 
        fill="none" stroke="url(#steamGradient)" stroke-width="4" stroke-linecap="round"/>

  <!-- Steam Wisps - Center -->
  <path d="M 100 68 Q 95 50 100 32 Q 105 15 100 5" 
        fill="none" stroke="url(#steamGradient)" stroke-width="4" stroke-linecap="round"/>

  <!-- Steam Wisps - Right -->
  <path d="M 120 65 Q 115 48 120 30 Q 125 18 120 8" 
        fill="none" stroke="url(#steamGradient)" stroke-width="4" stroke-linecap="round"/>

  <!-- Coffee Bean 1 (floating left) -->
  <g transform="translate(35, 55) rotate(-25)">
    <ellipse cx="0" cy="0" rx="6" ry="10" fill="#6B5344" stroke="#3D2817" stroke-width="1"/>
    <line x1="0" y1="-3" x2="0" y2="3" stroke="#3D2817" stroke-width="0.5"/>
  </g>

  <!-- Coffee Bean 2 (floating right) -->
  <g transform="translate(165, 50) rotate(30)">
    <ellipse cx="0" cy="0" rx="6" ry="10" fill="#6B5344" stroke="#3D2817" stroke-width="1"/>
    <line x1="0" y1="-3" x2="0" y2="3" stroke="#3D2817" stroke-width="0.5"/>
  </g>

  <!-- Coffee Bean 3 (floating bottom) -->
  <g transform="translate(170, 100) rotate(-45)">
    <ellipse cx="0" cy="0" rx="6" ry="10" fill="#6B5344" stroke="#3D2817" stroke-width="1"/>
    <line x1="0" y1="-3" x2="0" y2="3" stroke="#3D2817" stroke-width="0.5"/>
  </g>

  <!-- Decorative Circle Background (optional) -->
  <circle cx="100" cy="100" r="95" fill="none" stroke="#D4A574" stroke-width="2" opacity="0.6"/>
</svg>
